{
  "name": "avnei-yesod-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E tests for Avnei Yesod pilot user journey (Agent 28 verification)",
  "scripts": {
    "test": "playwright test",
    "test:desktop": "playwright test --project=desktop-chrome",
    "test:mobile": "playwright test --project=mobile-iphone",
    "test:headed": "playwright test --headed --project=desktop-chrome",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
