  },

  "structures_by_unit": {
    "bridge": {
      "name": "Bridge",
      "weeks": "1-5",
      "structures": [],
      "note": "No formal grammar in Bridge — focus on phonics + sight words + chunks."
    },

    "u1-aboutme": {
      "name": "Unit 1 · About Me",
      "weeks": "6-9",
      "structures": [
        {
          "id": "gr-to-be-affirmative",
          "name": "to be · affirmative",
          "introduced_in_week": 6,
          "forms": ["I am", "you are", "he is", "she is", "it is", "we are", "they are"],
          "examples": ["I am Maya.", "She is from Tel Aviv.", "We are in class 7."],
          "cefr_level": "Pre-A1"
        },
        {
          "id": "gr-to-be-negative",
          "name": "to be · negative",
          "introduced_in_week": 6,
          "forms": ["I am not / I'm not", "you aren't", "he isn't", "she isn't", "we aren't", "they aren't"],
          "examples": ["I'm not from London.", "She isn't 13."],
          "cefr_level": "Pre-A1"
        },
        {
          "id": "gr-to-be-questions",
          "name": "to be · yes/no questions",
          "introduced_in_week": 6,
          "forms": ["Am I...?", "Are you...?", "Is he...?", "Is she...?", "Are we...?", "Are they...?"],
          "examples": ["Are you Daniel?", "Is she from Israel?"],
          "cefr_level": "Pre-A1"
        },
        {
          "id": "gr-subject-pronouns",
          "name": "Subject Pronouns",
          "introduced_in_week": 7,
          "forms": ["I", "you", "he", "she", "it", "we", "they"],
          "examples": ["I live in Tel Aviv.", "She plays football."],
          "cefr_level": "Pre-A1"
        },
        {
          "id": "gr-possessive-adjectives",
          "name": "Possessive Adjectives",
          "introduced_in_week": 7,
          "forms": ["my", "your", "his", "her", "its", "our", "their"],
          "examples": ["My name is Maya.", "His brother is tall."],
          "cefr_level": "Pre-A1"
        }
      ]
    },

    "u2-family": {
      "name": "Unit 2 · Family & Home",
      "weeks": "10-13",
      "structures": [
        {
          "id": "gr-there-is-are",
          "name": "there is / there are",
          "introduced_in_week": 11,
          "forms": ["there is", "there are", "there isn't", "there aren't", "Is there...?", "Are there...?"],
          "examples": ["There is a sofa in the living room.", "Are there 4 chairs?"],
          "cefr_level": "Pre-A1 → A1-"
        },
        {
          "id": "gr-regular-plurals",
          "name": "Regular plurals",
          "introduced_in_week": 12,
          "forms": ["+s", "+es (after sh/ch/x/o)", "y → ies"],
          "examples": ["cat → cats", "box → boxes", "baby → babies"],
          "cefr_level": "A1-"
        },
        {
          "id": "gr-irregular-plurals",
          "name": "Irregular plurals",
          "introduced_in_week": 12,
          "forms": ["man → men", "woman → women", "child → children", "foot → feet"],
          "examples": ["man/men", "child/children"],
          "cefr_level": "A1-"
        },
        {
          "id": "gr-possessive-s",
          "name": "Possessive 's",
          "introduced_in_week": 13,
          "forms": ["noun + 's"],
          "examples": ["Maya's brother", "the teacher's book"],
          "cefr_level": "A1-",
          "tnufa_note": "Listed in Unit 2 description though not explicitly drilled per week — assumed implicit in family-tree project"
        }
      ]
    },

    "u3-school": {
      "name": "Unit 3 · School Life",
      "weeks": "14-17",
      "structures": [
        {
          "id": "gr-present-simple-affirmative",
          "name": "Present Simple · affirmative",
          "introduced_in_week": 14,
          "forms": ["I/you/we/they + V", "he/she/it + V+s"],
          "examples": ["I play football.", "She watches TV."],
          "cefr_level": "A1-"
        },
        {
          "id": "gr-present-simple-3rd-s",
          "name": "Present Simple · 3rd person -s",
          "introduced_in_week": 15,
          "forms": ["+s (default)", "+es (sh/ch/x/o)", "y → ies"],
          "examples": ["plays", "watches", "studies", "goes", "fixes"],
          "spelling_rules": {
            "default": "play → plays",
            "sh_ch_x_o": "watch → watches · go → goes · fix → fixes",
            "y_after_consonant": "study → studies"
          },
          "cefr_level": "A1"
        },
        {
          "id": "gr-present-simple-negative",
          "name": "Present Simple · negative",
          "introduced_in_week": 15,
          "forms": ["don't + V", "doesn't + V (3rd person)"],
          "examples": ["I don't play.", "He doesn't watch TV."],
          "cefr_level": "A1"
        },
        {
          "id": "gr-present-simple-questions",
          "name": "Present Simple · yes/no questions",
          "introduced_in_week": 15,
          "forms": ["Do + I/you/we/they + V?", "Does + he/she/it + V?"],
          "examples": ["Do you play football?", "Does she watch TV?"],
          "cefr_level": "A1"
        }
      ]
    },

    "u4-routine": {
      "name": "Unit 4 · Daily Routine",
      "weeks": "18-21",
      "structures": [
        {
          "id": "gr-frequency-adverbs-position",
          "name": "Frequency Adverbs · position",
          "introduced_in_week": 19,
          "rule_summary": "BEFORE main verb · AFTER 'to be'",
          "examples": [
            "I usually go to school. (before 'go')",
            "She is always happy. (after 'is')"
          ],
          "common_error": "Position errors — *I go always to school* / *I always am happy*",
          "cefr_level": "A1"
        }
      ]
    },

    "u5-food": {
      "name": "Unit 5 · Food & Drink",
      "weeks": "22-25",
      "structures": [
        {
          "id": "gr-like-v-ing",
          "name": "I like + V-ing",
          "introduced_in_week": 23,
          "forms": ["like + V-ing", "love + V-ing", "hate + V-ing", "don't like + V-ing"],
          "examples": ["I like eating pizza.", "She loves cooking."],
          "cefr_level": "A1"
        },
        {
          "id": "gr-would-like",
          "name": "would like + noun / to + V",
          "introduced_in_week": 23,
          "forms": ["would like + noun", "would like + to + V"],
          "examples": ["I would like a pizza.", "She would like to eat."],
          "cefr_level": "A1+"
        }
      ]
    },

    "u6-city": {
      "name": "Unit 6 · My City",
      "weeks": "26-28",
      "structures": [
        {
          "id": "gr-prepositions-of-place",
          "name": "Prepositions of Place",
          "introduced_in_week": 26,
          "prepositions": ["in", "on", "under", "next to", "between", "behind", "in front of"],
          "examples": ["The book is on the table.", "The school is next to the park."],
          "cefr_level": "Pre-A1 → A1-"
        },
        {
          "id": "gr-present-continuous",
          "name": "Present Continuous",
          "introduced_in_week": 27,
          "forms": ["is/are + V-ing"],
          "examples": ["She is reading a book.", "They are playing football."],
          "cefr_level": "A1"
        }
      ]
    },

    "u7-project": {
      "name": "Unit 7 · Free Time & Year Project",
      "weeks": "29-32",
      "structures": [
        {
          "id": "gr-present-simple-vs-continuous",
          "name": "Present Simple vs. Present Continuous",
          "introduced_in_week": 29,
          "contrast_rule": "Simple = habit/routine · Continuous = right now",
          "examples": [
            "I play football every Friday. (simple — habit)",
            "I am playing football now. (continuous — right now)"
          ],
          "cefr_level": "A1+"
        }
      ]
    }
  },

  "scope_outside_grade_7": {
    "note": "Held back to ח'-ט' (per tnufa-grade8/9.json):",
    "structures_not_in_grade_7": [
      "Past Simple (regular + irregular)",
      "Future (going to, will)",
      "Comparatives + superlatives",
      "Modals (can, must, should)",
      "Articles (a/an/the — advanced)",
      "Conditionals (zero + first)"
    ]
  },

