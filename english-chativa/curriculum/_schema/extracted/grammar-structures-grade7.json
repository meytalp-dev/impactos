  "$schema": "../../_schema/item-schema.json",
  "meta": {
    "title": "Grammar Structures · Grade 7 · Pre-A1 → A1",
    "source": "english-tnufa-grade7.json · all 32 weeks",
    "extractedAt": "2026-05-29",
    "approvedBy": "TBD — pending Meytal review",
    "cefr_range": "Pre-A1 → A1",
